{
  "name": "@openguardrails/oss",
  "version": "0.1.0",
  "description": "OpenGuardrails-OSS — Protect every action your agent takes. Open-source agent security scanner, red-team runner, and integration toolkit.",
  "license": "Apache-2.0",
  "author": {
    "name": "thomas-security",
    "email": "thomas@openguardrails.com",
    "url": "https://github.com/thomas-security"
  },
  "homepage": "https://openguardrails.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/openguardrails/openguardrails-oss.git"
  },
  "bugs": {
    "url": "https://github.com/openguardrails/openguardrails-oss/issues"
  },
  "keywords": [
    "agent-security",
    "llm-security",
    "ai-security",
    "red-teaming",
    "security-scanner",
    "claude-code",
    "mcp",
    "prompt-injection",
    "openguardrails"
  ],
  "type": "module",
  "bin": {
    "openguardrails": "./src/cli.ts",
    "ogr": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./scan": "./src/scan/index.ts",
    "./redteam": "./src/redteam/index.ts",
    "./sdk": "./src/integrations/sdk.ts"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "scan": "bun src/cli.ts scan",
    "redteam": "bun src/cli.ts redteam",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
