{
  "$id": "openguardrails:base",
  "$comment": "SYNCED from openguardrails/policy/base.policy.json (the authored PAP source) — do NOT edit here; this copy ships in the core package so any binding can resolve `$extends: \"openguardrails:base\"` through the dependency it already has. A sync-guard test asserts the functional content matches the source.",
  "version": "0.1.0",

  "composition": {
    "security.*": { "strategy": "deny-wins", "on_all_failed": "block" },
    "safety.toxicity": { "strategy": "quorum", "quorum": { "count": 2, "min_score": 0.8 }, "on_all_failed": "allow" },
    "safety.*": { "strategy": "deny-wins", "on_all_failed": "allow" },
    "default": { "strategy": "deny-wins" }
  },

  "config_rules": {
    "egress_allowlist": [
      "api.github.com", "*.github.com",
      "pypi.org", "files.pythonhosted.org",
      "registry.npmjs.org", "*.npmjs.org",
      "crates.io", "static.crates.io",
      "proxy.golang.org"
    ],
    "secret_env_markers": ["SECRET", "TOKEN", "AWS_", "PASSWORD", "PRIVATE_KEY"],
    "secret_read_markers": [
      "/.ssh/", "/.aws/", "/.netrc", "/.config/gh/", "/.config/gcloud",
      "id_rsa", "id_ed25519", "credentials", "/.env", ".env",
      "Keychains", "Local Storage", "Cookies"
    ],
    "command_rules": [
      {
        "id": "pipe-to-shell",
        "regex": "(curl|wget|fetch)\\b[^|]*\\|\\s*(ba|z|k)?sh\\b",
        "category": "security.malicious_command", "domain": "security",
        "decision": "require_approval", "score": 0.85,
        "why": "remote script fetched and piped directly into a shell"
      },
      {
        "id": "rm-rf-root",
        "regex": "rm\\s+-rf\\s+/(\\s|$)",
        "category": "security.malicious_command", "domain": "security",
        "decision": "block", "score": 0.95,
        "why": "recursive force-delete of the filesystem root"
      }
    ]
  },

  "content_rules": {
    "redact_secrets": true,
    "injection_from_untrusted": "block",
    "injection_from_unverified": "require_approval"
  },

  "sandbox": {
    "workspace_write": [".", "/tmp"],
    "deny_read": ["~/.ssh", "~/.aws", "~/.hermes/auth.json", "~/.netrc", "~/.config/gcloud"],
    "deny_write": [".env", "~/.gitconfig", "~/.zshrc", "~/.bashrc"],
    "egress_allowlist": ["api.github.com", "*.github.com", "pypi.org", "*.pypi.org", "files.pythonhosted.org"],
    "deny_egress": [],
    "resource_limits": { "cpus": 2, "memory_mb": 2048, "pids": 256 }
  }
}
