  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/node": "^22",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openguardrails/openguardrails",
    "directory": "integrations/agent/opencode"
  },
  "homepage": "https://openguardrails.com",
  "publishConfig": {
    "access": "public"
  }
