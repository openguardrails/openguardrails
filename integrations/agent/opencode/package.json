{
  "name": "openguardrails-instrumentation-opencode",
  "version": "0.1.1",
  "description": "Guard an opencode agent's tool calls through the OpenGuardrails (OGR) protocol \u2014 agent-configurable text/regex guardrails, or use your own model as the judge. No core changes.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "OpenGuardrails",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "opencode",
    "plugin",
    "ai",
    "agent",
    "security",
    "guardrails",
    "ogr",
    "openguardrails"
  ],
  "dependencies": {
